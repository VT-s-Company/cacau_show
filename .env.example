# ==================================================
# FREEPAY BRASIL API
# ==================================================
# Obtenha suas chaves em: https://freepaybrasil.com.br

FREEPAY_PUBLIC_KEY=pk_live_sua_chave_publica_aqui
FREEPAY_SECRET_KEY=sk_live_sua_chave_secreta_aqui
FREEPAY_BASE_URL=https://api.freepaybrasil.com
FREEPAY_WEBHOOK_URL=https://seu-dominio.com.br/api/webhook/freepay

# ==================================================
# DATABASE
# ==================================================

DATABASE_URL="file:./dev.db"

# ==================================================
# MAIL CONFIG
# ==================================================

MAIL_MAILER=brevo
MAIL_FROM_ADDRESS=no-reply@cacau-show.com.br
MAIL_FROM_NAME="Cacau Show"

# ==================================================
# BREVO API (Sendinblue)
# ==================================================
# Obtenha sua chave em: https://app.brevo.com/settings/keys/api

BREVO_API_URL=https://api.brevo.com/v3
BREVO_API_KEY=sua_api_key_brevo_v3_aqui

# Opcional
BREVO_DEFAULT_LIST_IDS=2,7
BREVO_DEFAULT_SENDER_NAME="Cacau Show"
BREVO_DEFAULT_SENDER_EMAIL=no-reply@cacau-show.com.br

# ==================================================
# ADMIN DASHBOARD
# ==================================================

ADMIN_ROUTE_HASH=seu_hash_personalizado_aqui
ADMIN_USERNAME=admin@cacau.com.br

# Senha padrão: admin1cacau123 (em produção, usar hash bcrypt)
# Gere um hash em: https://bcrypt-generator.com/ (rounds: 12)
ADMIN_PASSWORD_HASH=$2y$12$seu_hash_bcrypt_aqui
